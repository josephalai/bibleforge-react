# ── BibleForge Port Configuration ────────────────────────────────────────────
# Copy this to .env and adjust to avoid conflicts with other running projects.

APP_PORT=3001        # Public port you access in the browser / Docker host port
SERVER_PORT=3001     # Port Express listens on (Docker internal + local dev)
VITE_PORT=5173       # Vite dev server port (local dev only)
DB_PORT_HOST=3306    # MySQL host port (container always uses 3306 internally)
